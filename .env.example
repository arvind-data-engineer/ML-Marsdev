# Option 1, recommended: one SQLAlchemy database URL.
# Works with any SQLAlchemy-supported database if the matching driver is installed.
# Examples:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/products
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/products
# DATABASE_URL=sqlite:///Data/local.db
DATABASE_URL=

# Option 2: build the URL from parts.
DB_DRIVER=postgresql+psycopg2
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_SSLMODE=

# Bring-your-own-schema path. Return these columns:
# user_id, product_id, is_purchased, Product_name, latitude, longitude
# Optional product fields: category, category_name, price, unit, description, background_color, image
# Optional behavior fields: interaction_score, is_favorite, added_to_cart, cart_count, viewed, view_count
PROCESSED_DATA_QUERY=

# Existing app-schema defaults. Override these only if your table names/columns differ.
AUTH_USER_QUERY=SELECT * FROM auth_user
LIST_PRODUCT_QUERY=SELECT * FROM list_product
PRODUCT_ITEMS_QUERY=SELECT * FROM product_items
PRODUCT_CATEGORY_QUERY=SELECT * FROM product_category
USERS_FAVORITE_PRODUCT_QUERY=SELECT * FROM users_favoriteproduct
USERS_FAVORITE_LOCATION_QUERY=SELECT *, ST_Y(ST_AsText(location)) AS latitude, ST_X(ST_AsText(location)) AS longitude FROM users_favoritelocation WHERE ST_IsValid(location)
